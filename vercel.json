{
  "rewrites": [
    {
      "source": "/licitacoes",
      "destination": "https://inai-licita-es.vercel.app/licitacoes"
    },
    {
      "source": "/licitacoes/:path(.*)",
      "destination": "https://inai-licita-es.vercel.app/licitacoes/:path"
    },
    {
      "source": "/eupresidente/:path*",
      "destination": "/eupresidente/index.html"
    }
  ]
}
